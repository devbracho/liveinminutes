# Local development uses the DEV Supabase project (liveinminutes-dev).
# Production deploys on Vercel use the PROD Supabase project (liveinminutes-prod).
# Easiest local setup: `pnpm dlx vercel link && pnpm dlx vercel env pull .env.local`
# That fills these in for you from Vercel's Development scope.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-DEV-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- Postgres (Project Settings -> Database -> Connection string -> URI) ---
# Use the TRANSACTION POOLER (port 6543), not the direct connection.
# Replace [YOUR-PASSWORD] with the DB password you set when creating the project.
DATABASE_URL="postgresql://postgres.YOUR-DEV-PROJECT:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# --- Public site URL ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Admin (comma-separated emails, server-only) ---
ADMIN_EMAILS=""

# --- Supabase service role (server-only, bypasses RLS — never NEXT_PUBLIC_) ---
SUPABASE_SERVICE_ROLE_KEY=""
